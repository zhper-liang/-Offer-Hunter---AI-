# ===========================================
# 个人求职辅助文档库 - 环境变量配置
# ===========================================

# LLM 提供商 (选一个填入对应 API Key 即可)
# 可选: claude | openai | ollama | deepseek | zhipu | moonshot | dashscope | yi | siliconflow | custom
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# --- LLM API Keys (只需填你使用的那个) ---

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 智谱 GLM (https://open.bigmodel.cn)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# 月之暗面 Kimi (https://platform.moonshot.cn)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# 通义千问 (https://dashscope.console.aliyun.com)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 零一万物 Yi (https://platform.lingyiwanwu.com)
YI_API_KEY=
YI_BASE_URL=https://api.lingyiwanwu.com/v1
YI_MODEL=yi-large

# SiliconFlow 硅基流动 (https://siliconflow.cn) - 聚合多模型平台
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# ★ 自定义提供商 (接入任意第三方 API, LLM_PROVIDER=custom 时生效)
# CUSTOM_API_FORMAT 选 openai 或 claude, 取决于目标 API 兼容哪种格式
CUSTOM_API_FORMAT=openai            # openai | claude
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# --- Embedding 配置 ---
EMBEDDING_PROVIDER=chroma          # chroma | openai | sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB 配置 ---
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION=job_seeking_kb

# --- 语音服务 (模拟面试用, 可选) ---

# 讯飞语音 (https://www.xfyun.cn)
IFLYTEK_APP_ID=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=

# 百度语音 (https://ai.baidu.com/tech/speech) - 备选
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# --- 应用配置 ---
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20
